<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cinema.persistence.mybatis.dao.MovieDao">

    <resultMap id="movieResultMap" type="com.cinema.domain.Movie">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="durationMinutes" column="duration_minutes"/>
        <result property="genres" column="genres"/>
    </resultMap>

    <select id="findAll" resultMap="movieResultMap">
        SELECT id, title, duration_minutes, genres
        FROM movies
        ORDER BY id
    </select>

    <select id="findById" parameterType="long" resultMap="movieResultMap">
        SELECT id, title, duration_minutes, genres
        FROM movies
        WHERE id = #{id}
    </select>

</mapper>