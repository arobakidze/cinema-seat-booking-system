<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cinema.persistence.mybatis.dao.SeatDao">

    <resultMap id="seatResultMap" type="com.cinema.domain.Seat">
        <id property="id" column="id"/>
        <result property="hallId" column="hall_id"/>
        <result property="rowNum" column="row_num"/>
        <result property="seatNumber" column="seat_number"/>
        <result property="isBooked" column="is_booked"/>
    </resultMap>

    <select id="findAll" resultMap="seatResultMap">
        SELECT * FROM seats
    </select>

    <select id="findById" parameterType="Long" resultMap="seatResultMap">
        SELECT * FROM seats WHERE id = #{id}
    </select>

    <select id="findByHallId" parameterType="Long" resultMap="seatResultMap">
        SELECT * FROM seats WHERE hall_id = #{hallId}
    </select>

    <select id="findAvailableBySessionId" parameterType="Long" resultMap="seatResultMap">
        SELECT s.* FROM seats s
        JOIN cinema_halls h ON s.hall_id = h.id
        JOIN movie_sessions ms ON ms.hall_id = h.id
        WHERE ms.id = #{sessionId} AND s.is_booked = false
    </select>

    <insert id="insert" parameterType="com.cinema.domain.Seat" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO seats (hall_id, row_num, seat_number, is_booked)
        VALUES (#{hallId}, #{rowNum}, #{seatNumber}, #{isBooked})
    </insert>

    <update id="update" parameterType="com.cinema.domain.Seat">
        UPDATE seats SET hall_id = #{hallId}, row_num = #{rowNum},
        seat_number = #{seatNumber}, is_booked = #{isBooked}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="Long">
        DELETE FROM seats WHERE id = #{id}
    </delete>

</mapper>
