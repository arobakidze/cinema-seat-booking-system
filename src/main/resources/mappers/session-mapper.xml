<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cinema.persistence.mybatis.dao.MovieSessionDao">

    <resultMap id="movieSessionResultMap" type="com.cinema.domain.MovieSession">
        <id property="id" column="id"/>
        <result property="movieId" column="movie_id"/>
        <result property="hallId" column="hall_id"/>
        <result property="startTime" column="start_time"/>
    </resultMap>

    <select id="findAll" resultMap="movieSessionResultMap">
        SELECT id, movie_id, hall_id, start_time
        FROM movie_sessions
        ORDER BY start_time
    </select>

    <select id="findByMovieId" parameterType="long" resultMap="movieSessionResultMap">
        SELECT id, movie_id, hall_id, start_time
        FROM movie_sessions
        WHERE movie_id = #{movieId}
        ORDER BY start_time
    </select>

    <select id="findById" parameterType="long" resultMap="movieSessionResultMap">
        SELECT id, movie_id, hall_id, start_time
        FROM movie_sessions
        WHERE id = #{id}
    </select>

</mapper>